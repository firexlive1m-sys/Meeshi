# Cashfree Payments API Configuration
# Get these keys from https://merchant.cashfree.com/
CASHFREE_APP_ID=YOUR_CASHFREE_APP_ID_HERE
CASHFREE_SECRET_KEY=YOUR_CASHFREE_SECRET_KEY_HERE

# Environment: 'sandbox' or 'production' (default is 'sandbox')
CASHFREE_ENV=sandbox

# Gemini API Key (Server-Side Only)
GEMINI_API_KEY=
